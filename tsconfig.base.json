{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@cbj/react-obs-core": ["./packages/core/src/index.ts"],
      "@cbj/react-obs-core/builders": ["./packages/core/src/builders.ts"],
      "@cbj/react-obs-frame": ["./packages/frame/src/index.ts"],
      "@cbj/react-obs-frame/client": ["./packages/frame/src/client.ts"],
      "@cbj/react-obs-frame/server": ["./packages/frame/src/server.ts"],
      "@cbj/react-obs-frame/vite": ["./packages/frame/src/vite.ts"],
      "@cbj/react-obs-moq": ["./packages/moq/src/index.ts"],
      "@cbj/react-obs-moq/dom": ["./packages/moq/src/dom.ts"],
      "@cbj/react-obs-moq/obs": ["./packages/moq/src/obs.ts"],
      "@cbj/react-obs-moq/react": ["./packages/moq/src/react.ts"],
      "@cbj/react-obs": ["./packages/react/src/index.ts"],
      "@cbj/react-obs-server": ["./packages/server/src/index.ts"],
      "@cbj/react-obs-target-dom": ["./packages/target-dom/src/index.ts"],
      "@cbj/react-obs-target-dom/react": ["./packages/target-dom/src/react.ts"],
      "@cbj/react-obs-target-obs": ["./packages/target-obs/src/index.ts"],
      "@cbj/react-obs-testkit": ["./packages/testkit/src/index.ts"]
    },
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "useUnknownInCatchVariables": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "noEmitOnError": true
  }
}
