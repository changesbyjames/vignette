{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@strangecyan/vignette-core": ["./packages/core/src/index.ts"],
      "@strangecyan/vignette-core/builders": ["./packages/core/src/builders.ts"],
      "@strangecyan/vignette-core/layout-yoga": ["./packages/core/src/layout/layout-yoga.ts"],
      "@strangecyan/vignette-core/runtime": ["./packages/core/src/runtime-api.ts"],
      "@strangecyan/vignette-core/sse": ["./packages/core/src/sse-codec.ts"],
      "@strangecyan/vignette-frame": ["./packages/frame/src/index.ts"],
      "@strangecyan/vignette-frame/client": ["./packages/frame/src/client.ts"],
      "@strangecyan/vignette-frame/server": ["./packages/frame/src/server.ts"],
      "@strangecyan/vignette-frame/server/node": ["./packages/frame/src/node-server.ts"],
      "@strangecyan/vignette-frame/transform": ["./packages/frame/src/transform.ts"],
      "@strangecyan/vignette-vite": ["./packages/vite/src/index.ts"],
      "@strangecyan/vignette-moq": ["./packages/moq/src/index.ts"],
      "@strangecyan/vignette-moq/dom": ["./packages/moq/src/dom.ts"],
      "@strangecyan/vignette-moq/obs": ["./packages/moq/src/obs.ts"],
      "@strangecyan/vignette-moq/react": ["./packages/moq/src/react.ts"],
      "@strangecyan/vignette-preview": ["./packages/preview/src/index.ts"],
      "@strangecyan/vignette": ["./packages/react/src/index.ts"],
      "@strangecyan/vignette-target-dom": ["./packages/target-dom/src/index.ts"],
      "@strangecyan/vignette-target-dom/react": ["./packages/target-dom/src/react.ts"],
      "@strangecyan/vignette-target-obs": ["./packages/target-obs/src/index.ts"],
      "@strangecyan/vignette-testkit": ["./packages/testkit/src/index.ts"]
    },
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "useUnknownInCatchVariables": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "noEmitOnError": true
  }
}
