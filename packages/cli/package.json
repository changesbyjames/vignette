{
  "name": "@strangecyan/vignette-cli",
  "version": "0.4.1",
  "description": "Command-line helpers for Vignette projects.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/changesbyjames/vignette.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "files": [
    "bin",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "vignette": "./bin/vignette.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. packages/cli",
    "publish:check": "pnpm publish --dry-run --no-git-checks"
  },
  "dependencies": {
    "@strangecyan/vignette-core": "workspace:^",
    "@strangecyan/vignette-moq": "workspace:^",
    "@strangecyan/vignette-target-dom": "workspace:^",
    "@strangecyan/vignette-target-obs": "workspace:^",
    "playwright": "1.61.1"
  },
  "devDependencies": {
    "@types/node": "26.1.1"
  }
}
