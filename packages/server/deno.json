{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "name": "@cbj/vignette-server",
  "version": "0.2.0",
  "license": "MIT",
  "imports": {
    "@cbj/vignette": "jsr:@cbj/vignette@^0.2.0",
    "@cbj/vignette-core": "jsr:@cbj/vignette-core@^0.2.0",
    "@cbj/vignette-core/": "jsr:@cbj/vignette-core@^0.2.0/",
    "@cbj/vignette-frame": "jsr:@cbj/vignette-frame@^0.2.0",
    "@cbj/vignette-frame/": "jsr:@cbj/vignette-frame@^0.2.0/"
  },
  "exports": {
    ".": "./src/index.ts",
    "./node": "./src/node.ts"
  },
  "publish": {
    "include": ["README.md", "package.json", "src/**/*.ts"],
    "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
  }
}
