  "license": "MIT",
  "imports": {
    "@cbj/vignette": "jsr:@cbj/vignette@^0.2.1",
    "@cbj/vignette-core": "jsr:@cbj/vignette-core@^0.2.1",
    "@cbj/vignette-core/runtime": "jsr:@cbj/vignette-core@^0.2.1/runtime",
    "@cbj/vignette-core/sse": "jsr:@cbj/vignette-core@^0.2.1/sse",
    "@cbj/vignette-frame": "jsr:@cbj/vignette-frame@^0.2.1",
    "@cbj/vignette-frame/server": "jsr:@cbj/vignette-frame@^0.2.1/server",
    "react": "npm:react@19.2.7"
