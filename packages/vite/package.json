{
  "name": "@strangecyan/vignette-vite",
  "version": "0.3.5",
  "description": "Vite build integration for Vignette frames and composition assets.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/changesbyjames/vignette.git",
    "directory": "packages/vite"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src/virtual.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./frame-client": {
      "types": "./dist/frame-client.d.ts",
      "default": "./dist/frame-client.js"
    },
    "./virtual": {
      "types": "./src/virtual.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. packages/vite",
    "publish:check": "pnpm publish --dry-run --no-git-checks"
  },
  "dependencies": {
    "@strangecyan/vignette-core": "workspace:^",
    "@strangecyan/vignette-frame": "workspace:^",
    "tinyglobby": "0.2.17"
  },
  "peerDependencies": {
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "vite": "8.1.4"
  }
}
