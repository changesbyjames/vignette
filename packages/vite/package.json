{
  "name": "@cbj/vignette-vite",
  "version": "0.3.0",
  "description": "Vite build integration for Vignette frames and composition assets.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./virtual": {
      "types": "./src/virtual.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. packages/vite"
  },
  "dependencies": {
    "@cbj/vignette-core": "workspace:^",
    "@cbj/vignette-frame": "workspace:^",
    "tinyglobby": "0.2.17"
  },
  "peerDependencies": {
    "vite": "8.1.4"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "vite": "8.1.4"
  }
}
