{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "name": "@cbj/vignette-core",
  "version": "0.3.3",
  "license": "MIT",
  "imports": {
    "yoga-layout": "npm:yoga-layout@3.2.1",
    "yoga-layout/load": "npm:yoga-layout@3.2.1/load"
  },
  "exports": {
    ".": "./src/index.ts",
