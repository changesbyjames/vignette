{
  "name": "@strangecyan/vignette-core",
  "version": "0.4.1",
  "description": "Target-neutral scene graph, Yoga layout compiler, snapshots, and runtime contracts for Vignette.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/changesbyjames/vignette.git",
    "directory": "packages/core"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./builders": {
      "types": "./dist/builders.d.ts",
      "default": "./dist/builders.js"
    },
    "./runtime": {
      "types": "./dist/runtime-api.d.ts",
      "default": "./dist/runtime-api.js"
    },
    "./sse": {
      "types": "./dist/sse-codec.d.ts",
      "default": "./dist/sse-codec.js"
    },
    "./layout-yoga": {
      "types": "./dist/layout/layout-yoga.d.ts",
      "default": "./dist/layout/layout-yoga.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. packages/core",
    "publish:check": "pnpm publish --dry-run --no-git-checks"
  },
  "dependencies": {
    "yoga-layout": "3.2.1"
  }
}