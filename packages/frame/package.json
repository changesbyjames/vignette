{
  "name": "@cbj/vignette-frame",
  "version": "0.1.2",
  "description": "Typed React DOM frames with Vite SSR and hydration for Vignette browser sources.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "default": "./dist/vite.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. packages/frame",
    "publish:check": "pnpm dlx jsr publish --dry-run --allow-dirty"
  },
  "dependencies": {
    "@cbj/vignette-core": "workspace:^",
    "@cbj/vignette": "workspace:^",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vite": "8.1.4"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vite": "8.1.4"
  }
}
