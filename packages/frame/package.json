{
  "name": "@strangecyan/vignette-frame",
  "version": "0.4.1",
  "description": "Typed React DOM frames with Vite SSR and hydration for Vignette browser sources.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/changesbyjames/vignette.git",
    "directory": "packages/frame"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./remote-store": {
      "types": "./dist/remote-store.d.ts",
      "default": "./dist/remote-store.js"
    },
    "./remote-store/client": {
      "types": "./dist/remote-store-client.d.ts",
      "default": "./dist/remote-store-client.js"
    },
    "./remote-store/server": {
      "types": "./dist/remote-store-server.d.ts",
      "default": "./dist/remote-store-server.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./server/node": {
      "types": "./dist/node-server.d.ts",
      "default": "./dist/node-server.js"
    },
    "./transform": {
      "types": "./dist/transform.d.ts",
      "default": "./dist/transform.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. packages/frame",
    "publish:check": "pnpm publish --dry-run --no-git-checks"
  },
  "dependencies": {
    "@strangecyan/vignette-core": "workspace:^",
    "@strangecyan/vignette": "workspace:^",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
