{
  "name": "@strangecyan/vignette",
  "version": "0.4.1",
  "description": "React renderer and authoring primitives for target-neutral broadcast scenes.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/changesbyjames/vignette.git",
    "directory": "packages/react"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. packages/react",
    "publish:check": "pnpm publish --dry-run --no-git-checks"
  },
  "dependencies": {
    "@strangecyan/vignette-core": "workspace:^",
    "react-reconciler": "0.33.0"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@strangecyan/vignette-testkit": "workspace:^",
    "@types/react": "19.2.17",
    "@types/react-reconciler": "0.33.0",
    "react": "19.2.7"
  }
}