{
  "name": "@strangecyan/vignette-target-dom",
  "version": "0.4.1",
  "description": "Browser DOM runtime and React compositor hook for Vignette snapshots.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/changesbyjames/vignette.git",
    "directory": "packages/target-dom"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. packages/target-dom",
    "publish:check": "pnpm publish --dry-run --no-git-checks"
  },
  "dependencies": {
    "@strangecyan/vignette-core": "workspace:^",
    "ramda": "0.32.0"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/ramda": "0.32.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
