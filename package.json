{
  "name": "vignette-workspace",
  "version": "0.3.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/changesbyjames/vignette.git"
  },
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b && pnpm --filter @cbj/vignette-kitchen-sink build:app",
    "clean": "tsc -b --clean && pnpm -r --if-present clean",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:e2e": "playwright test examples/kitchen-sink/tests/dom.spec.ts",
    "test:obs-integration": "playwright test examples/kitchen-sink/tests/obs-integration.spec.ts",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "publish:check": "node scripts/check-jsr-docs.mjs && node scripts/check-jsr-packages.mjs",
    "ready": "pnpm build && pnpm typecheck && pnpm test && pnpm lint && pnpm format:check && pnpm publish:check && pnpm test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "jsdom": "29.1.1",
    "jsr": "0.14.3",
    "obs-websocket-js": "5.0.8",
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0",
    "@types/pngjs": "6.0.5",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
